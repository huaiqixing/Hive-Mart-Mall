NODE_ENV=development
VITE_DEV=true

# 后端地址
VITE_BASE_URL='http://localhost:48080'

# API 前缀（商城使用 app-api，与管理后台 admin-api 不同）
VITE_API_URL=/app-api

# 上传方式
VITE_UPLOAD_TYPE=server

# 标题
VITE_APP_TITLE=HiveMart 商城

# 端口
VITE_PORT=3000

# 租户ID
VITE_TENANT_ID=1

# 构建配置
VITE_BASE_PATH=/
VITE_DROP_CONSOLE=false
VITE_SOURCEMAP=false
